{
  "openapi": "3.1.0",
  "info": {
    "title": "x402 Full Payment Firewall API",
    "version": "0.2.0",
    "description": "Tenant-authenticated, stateful x402 payment policy enforcement with durable budgets, replay protection, reservations, and settlement lifecycle."
  },
  "servers": [{ "url": "https://x402-payment-firewall.vercel.app" }],
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/api/v1/policies": {
      "post": {
        "operationId": "createPolicy",
        "summary": "Create a server-side firewall policy",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": false,
                "required": ["name", "policy"],
                "properties": {
                  "name": { "type": "string", "minLength": 1, "maxLength": 100 },
                  "policy": { "$ref": "#/components/schemas/FirewallPolicy" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Policy created" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "get": {
        "operationId": "getPolicy",
        "summary": "Get a server-side firewall policy",
        "parameters": [{ "in": "query", "name": "id", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": {
          "200": { "description": "Policy" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "description": "Policy not found" }
        }
      }
    },
    "/api/v1/evaluate": {
      "post": {
        "operationId": "evaluatePaymentWithStoredPolicy",
        "summary": "Reserve budget and authorize an x402 payment",
        "description": "Loads a tenant-owned policy, validates the payment, atomically enforces daily budgets, and blocks active or settled replay fingerprints. An allow response includes a short-lived authorization token.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": false,
                "required": ["policyId", "input"],
                "properties": {
                  "policyId": { "type": "string", "format": "uuid" },
                  "input": { "$ref": "#/components/schemas/PaymentEvaluationInput" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Allow or deny decision",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CloudDecision" } } }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/decisions": {
      "post": {
        "operationId": "finalizePaymentDecision",
        "summary": "Settle or cancel a reserved decision",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": false,
                "required": ["decisionId", "authorizationToken", "outcome"],
                "properties": {
                  "decisionId": { "type": "string", "format": "uuid" },
                  "authorizationToken": { "type": "string" },
                  "outcome": { "type": "string", "enum": ["settled", "cancelled"] }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Decision finalized" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "409": { "description": "Decision is no longer reserved" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "x402fw_live API key" }
    },
    "responses": {
      "Unauthorized": { "description": "Missing, invalid, or revoked API key" }
    },
    "schemas": {
      "AmountLimit": {
        "type": "object",
        "additionalProperties": false,
        "required": ["network", "asset", "amount"],
        "properties": {
          "network": { "type": "string" },
          "asset": { "type": "string" },
          "amount": { "type": "string", "pattern": "^(0|[1-9][0-9]*)$" }
        }
      },
      "FirewallPolicy": {
        "type": "object",
        "minProperties": 1,
        "additionalProperties": false,
        "properties": {
          "allowedDomains": { "type": "array", "items": { "type": "string" } },
          "allowedNetworks": { "type": "array", "items": { "type": "string" } },
          "allowedAssets": { "type": "array", "items": { "type": "string" } },
          "allowedSchemes": { "type": "array", "items": { "type": "string" } },
          "allowedRecipients": { "type": "array", "items": { "type": "string" } },
          "recipientPins": { "type": "object", "additionalProperties": { "type": "array", "items": { "type": "string" } } },
          "maxPerRequest": { "type": "array", "items": { "$ref": "#/components/schemas/AmountLimit" } },
          "dailyBudgets": { "type": "array", "items": { "$ref": "#/components/schemas/AmountLimit" } },
          "bindRequestDomain": { "type": "boolean", "default": true },
          "duplicateTtlMs": { "type": "integer", "minimum": 30000, "maximum": 900000 }
        }
      },
      "PaymentRequirements": {
        "type": "object",
        "additionalProperties": false,
        "required": ["scheme", "network", "amount", "asset", "payTo"],
        "properties": {
          "scheme": { "type": "string" },
          "network": { "type": "string" },
          "amount": { "type": "string", "pattern": "^(0|[1-9][0-9]*)$" },
          "asset": { "type": "string" },
          "payTo": { "type": "string" },
          "maxTimeoutSeconds": { "type": "integer", "minimum": 1 },
          "extra": { "type": "object" }
        }
      },
      "PaymentEvaluationInput": {
        "type": "object",
        "additionalProperties": false,
        "required": ["paymentRequired", "selectedRequirements", "request"],
        "properties": {
          "paymentRequired": {
            "type": "object",
            "required": ["x402Version", "resource", "accepts"],
            "properties": {
              "x402Version": { "const": 2 },
              "resource": { "type": "object", "required": ["url"], "properties": { "url": { "type": "string", "format": "uri" } } },
              "accepts": { "type": "array", "minItems": 1, "items": { "$ref": "#/components/schemas/PaymentRequirements" } }
            }
          },
          "selectedRequirements": { "$ref": "#/components/schemas/PaymentRequirements" },
          "request": {
            "type": "object",
            "required": ["agentId", "url"],
            "properties": {
              "agentId": { "type": "string" },
              "sessionId": { "type": "string" },
              "tool": { "type": "string" },
              "intent": { "type": "string" },
              "method": { "type": "string" },
              "url": { "type": "string", "format": "uri" },
              "bodyHash": { "type": "string" }
            }
          }
        }
      },
      "CloudDecision": {
        "type": "object",
        "required": ["mode", "policyId", "decision"],
        "properties": {
          "mode": { "const": "enforced" },
          "policyId": { "type": "string", "format": "uuid" },
          "decision": { "type": "object" },
          "authorizationToken": { "type": "string" },
          "reservation": { "type": "object" }
        }
      }
    }
  }
}
